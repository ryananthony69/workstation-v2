<Window x:Class="WorkstationV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WorkstationV2.Controls"
        Title="Workstation v2" WindowState="Maximized" MinWidth="1200" MinHeight="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <!-- Left: 2x2 grid -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:BrowserTile x:Name="Tile1" Grid.Row="0" Grid.Column="0" TileId="1" />
            <controls:BrowserTile x:Name="Tile2" Grid.Row="0" Grid.Column="1" TileId="2" />
            <controls:BrowserTile x:Name="Tile3" Grid.Row="1" Grid.Column="0" TileId="3" />
            <controls:CanvasPanel x:Name="CanvasPanel" Grid.Row="1" Grid.Column="1" />
        </Grid>

        <!-- Right sidebar -->
        <Grid Grid.Column="1" Background="#111111">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="10" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                <TextBlock Text="Tools + Script Runner" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="260" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Tools" Margin="10" Foreground="White" BorderBrush="#2A2A2A">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid x:Name="ToolsGrid" Columns="3" Margin="6"/>
                    </ScrollViewer>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Script Runner" Margin="10" Foreground="White" BorderBrush="#2A2A2A">
                    <controls:ScriptRunner x:Name="ScriptRunner"/>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Window>