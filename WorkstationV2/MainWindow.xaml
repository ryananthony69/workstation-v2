<Window x:Class="WorkstationV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WorkstationV2.Controls"
        Title="Workstation v2" WindowState="Maximized" MinWidth="1200" MinHeight="800"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition x:Name="SidebarCol" Width="380" MinWidth="280" />
        </Grid.ColumnDefinitions>

        <!-- Left: 2x2 grid with splitters -->
        <Grid Grid.Column="0" x:Name="LeftGrid">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="LeftRowTop" Height="*" />
                <RowDefinition Height="6" />
                <RowDefinition x:Name="LeftRowBottom" Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftColLeft" Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="LeftColRight" Width="*" />
            </Grid.ColumnDefinitions>

            <controls:BrowserTile x:Name="Tile1" Grid.Row="0" Grid.Column="0" TileId="1" />
            <controls:BrowserTile x:Name="Tile2" Grid.Row="0" Grid.Column="2" TileId="2" />
            <controls:BrowserTile x:Name="Tile3" Grid.Row="2" Grid.Column="0" TileId="3" />
            <controls:CanvasPanel x:Name="CanvasPanel" Grid.Row="2" Grid.Column="2" />

            <!-- Vertical splitter between left/right columns -->
            <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          DragCompleted="Splitter_DragCompleted"
                          Background="#2A2A2A" />

            <!-- Horizontal splitter between top/bottom rows -->
            <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          DragCompleted="Splitter_DragCompleted"
                          Background="#2A2A2A" />
        </Grid>

        <!-- Sidebar splitter -->
        <GridSplitter Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      DragCompleted="Splitter_DragCompleted"
                      Background="#2A2A2A" />

        <!-- Right sidebar -->
        <Grid Grid.Column="2" Background="#111111">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="10" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                <TextBlock Text="Tools + Script Runner" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="260" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Tools" Margin="10" Foreground="White" BorderBrush="#2A2A2A">
                    <StackPanel Margin="6">
                        <Border x:Name="ToolsErrorBanner"
                                Background="#3A1A1A"
                                BorderBrush="#AA3333"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Margin="0,0,0,8"
                                Visibility="Collapsed">
                            <TextBlock x:Name="ToolsErrorText" Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="ToolsSearchBox"
                                     MinHeight="26"
                                     VerticalContentAlignment="Center"
                                     TextChanged="ToolsSearch_TextChanged"
                                     KeyDown="ToolsSearch_KeyDown"/>
                        </DockPanel>

                        <WrapPanel Margin="0,0,0,8">
                            <Button x:Name="ReloadToolsButton" Content="Reload" Padding="10,4" Margin="0,0,8,0" Click="ReloadTools_Click"/>
                            <Button x:Name="OpenToolsButton" Content="Open Tools.json" Padding="10,4" Margin="0,0,8,0" Click="OpenTools_Click"/>
                            <Button x:Name="ExportToolsButton" Content="Export (Clipboard)" Padding="10,4" Margin="0,0,8,0" Click="ExportTools_Click"/>
                            <Button x:Name="ImportToolsButton" Content="Import..." Padding="10,4" Click="ImportTools_Click"/>
                        </WrapPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <UniformGrid x:Name="ToolsGrid" Columns="3"/>
                        </ScrollViewer>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Script Runner" Margin="10" Foreground="White" BorderBrush="#2A2A2A">
                    <controls:ScriptRunner x:Name="ScriptRunner"/>
                </GroupBox>

                <!-- Toast overlay -->
                <Border x:Name="ToastBorder"
                        Grid.RowSpan="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="10"
                        Padding="10,6"
                        Background="#222222"
                        BorderBrush="#2A2A2A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Panel.ZIndex="50">
                    <TextBlock x:Name="ToastText" Foreground="White" FontSize="12" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>