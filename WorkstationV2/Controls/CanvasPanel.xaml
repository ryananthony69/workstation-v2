<UserControl x:Class="WorkstationV2.Controls.CanvasPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Canvas Control Panel" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Vault:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="VaultBox" Grid.Column="1" MinHeight="26" VerticalContentAlignment="Center" Margin="0,0,6,0"/>
            <Button Grid.Column="2" Content="Browse" Padding="10,4" Click="BrowseVault_Click"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Canvas:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="CanvasBox" Grid.Column="1" MinHeight="26" VerticalContentAlignment="Center" Margin="0,0,6,0"/>
            <Button Grid.Column="2" Content="Pick" Padding="10,4" Click="PickCanvas_Click"/>
        </Grid>

        <WrapPanel Grid.Row="3">
            <Button Content="Open Canvas" Padding="10,4" Margin="0,0,8,0" Click="OpenCanvas_Click"/>
            <Button Content="Open Vault" Padding="10,4" Margin="0,0,8,0" Click="OpenVault_Click"/>
            <Button Content="Focus Obsidian" Padding="10,4" Click="FocusObsidian_Click"/>
        </WrapPanel>
    </Grid>
</UserControl>