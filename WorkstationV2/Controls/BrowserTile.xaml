<UserControl x:Class="WorkstationV2.Controls.BrowserTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinWidth="200" MinHeight="200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="6">
            <TextBlock Text="URL:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="UrlBox"
                     MinHeight="26"
                     VerticalContentAlignment="Center"
                     KeyDown="UrlBox_KeyDown"
                     DockPanel.Dock="Left"
                     Margin="0,0,6,0"/>
            <Button x:Name="GoButton" Content="Go" Padding="10,4" Click="Go_Click"/>
        </DockPanel>

        <Border Grid.Row="1" Margin="6" BorderBrush="#2A2A2A" BorderThickness="1">
            <wv2:WebView2 x:Name="Web"/>
        </Border>
    </Grid>
</UserControl>