<UserControl x:Class="WorkstationV2.Controls.BrowserTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinWidth="300" MinHeight="200">
    <Border BorderBrush="#2A2A2A" BorderThickness="1" Margin="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="6">
                <TextBox x:Name="UrlBox"
                         MinHeight="28"
                         VerticalContentAlignment="Center"
                         Margin="0,0,6,0"
                         DockPanel.Dock="Left"
                         KeyDown="UrlBox_KeyDown"/>
                <Button Content="Go" MinHeight="28" Padding="10,2" Click="Go_Click"/>
            </DockPanel>

            <Grid Grid.Row="1">
                <wv2:WebView2 x:Name="Web" />
            </Grid>
        </Grid>
    </Border>
</UserControl>