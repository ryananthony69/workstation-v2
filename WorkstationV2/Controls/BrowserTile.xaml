<UserControl x:Class="WorkstationV2.Controls.BrowserTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="200" MinHeight="200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="6">
            <TextBlock Text="URL:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="UrlBox"
                     MinHeight="26"
                     VerticalContentAlignment="Center"
                     KeyDown="UrlBox_KeyDown"
                     DockPanel.Dock="Left"
                     Margin="0,0,6,0"/>
            <Button x:Name="GoButton" Content="Go" Padding="10,4" Click="Go_Click"/>
        </DockPanel>

        <Border Grid.Row="1" Margin="6" BorderBrush="#2A2A2A" BorderThickness="1">
            <Grid>
                <Grid x:Name="WebHost" />
                <Border x:Name="WebFallback"
                        Background="#101010"
                        Opacity="0.95"
                        Visibility="Collapsed">
                    <TextBlock x:Name="WebFallbackText"
                               Foreground="White"
                               TextWrapping="Wrap"
                               Margin="12"
                               Text="Browser unavailable."/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>