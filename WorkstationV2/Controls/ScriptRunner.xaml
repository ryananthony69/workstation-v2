<UserControl x:Class="WorkstationV2.Controls.ScriptRunner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Input (Ctrl+Enter to run)" Margin="0,0,0,6"/>

        <TextBox Grid.Row="1" x:Name="InputBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 MinHeight="120"
                 KeyDown="InputBox_KeyDown"/>

        <DockPanel Grid.Row="2" Margin="0,10,0,10">
            <Button x:Name="RunButton" Content="Run" Padding="12,4" Click="Run_Click" />
            <TextBlock x:Name="StatusText" Margin="12,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>

        <TextBox Grid.Row="3" x:Name="OutputBox"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 MinHeight="120"/>
    </Grid>
</UserControl>